# Dependencies
node_modules/

# Build
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Test / coverage
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Caches
.npm/
.eslintcache
.stylelintcache
*.tsbuildinfo
.vite/
.cache/
.turbo/
.parcel-cache/

# Environment (keep !.env.example if you add one)
.env
.env.*
!.env.example

# npm pack output
*.tgz

# Vite config timestamps
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Firebase CLI / hosting cache
.firebase/

# OS
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Local agent / AI tooling (not shared project source)
.agents/
.cursor/
.claude/
.kilocode/
skills-lock.json

# Archived python-prototype local artifacts only
python-prototype/**/__pycache__/
python-prototype/**/*.py[cod]
python-prototype/**/*$py.class
python-prototype/.venv/
python-prototype/*.egg-info/
